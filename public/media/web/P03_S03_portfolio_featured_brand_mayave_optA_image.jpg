document.addEventListener("DOMContentLoaded", function() {
  const btn = document.querySelector(".more-about-author-btn");
  const modal = document.querySelector(".about-author-modal");

  // Открытие модалки при клике на кнопку
  btn.addEventListener("click", function(e) {
    e.stopPropagation(); // чтобы клик не сработал на document
    modal.classList.add("about-author-modal__visible");
  });

  // Закрытие модалки при клике вне её
  document.addEventListener("click", function() {
    modal.classList.remove("about-author-modal__visible");
  });

  // Предотвращение закрытия при клике внутри модалки
  modal.addEventListener("click", function(e) {
    e.stopPropagation();
  });
});
</script></div></div></div></div><div class="article-mini-info"><div class="article-hero-info-date article-hero-info-date__5-col"><div class="article-hero-info-text t-color-black">June 19, 2023</div><div class="circle circle-black"></div><div class="article-hero-info-time"><div class="article-hero-info-text t-color-black mr-02em">10</div><div class="article-hero-info-text t-color-black">MIN READ</div></div><div class="circle circle-black w-condition-invisible"></div><div class="article-hero-info-text t-color-black w-condition-invisible w-dyn-bind-empty"></div></div><div class="article-overview"><div class="t-16-500 t-color-404040 t-mob-14">Discover how to blend jewelry product photos with the emotional purchase. Learn how to shoot necklaces, rings, and bracelets.</div></div></div><div class="article-hero-share-block"><div class="w-embed w-script"><script>
