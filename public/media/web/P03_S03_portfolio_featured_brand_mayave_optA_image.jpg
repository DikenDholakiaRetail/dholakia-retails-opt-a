<script>
// A universal manager for "printed" text animation
(function () {
  const instances = new Map(); // key -> {element, chars, settings, visibleCount, ticking}
  let rafScheduled = false;

  const defaults = { startRatio: 0.7, endRatio: 0.3 };

  function clamp(v, a, b) { return Math.max(a, Math.min(b, v)); }

  function splitToChars(textBlock) {
    // Если уже обработан — вернем null
    if (textBlock.dataset.__animTextProcessed) return null;

    const originalHTML = textBlock.innerHTML;
    textBlock.innerHTML = "";

    function processNode(node, parentElement) {
      if (node.nodeType === Node.TEXT_NODE) {
        node.textContent.split("").forEach((char) => {
          const charSpan = document.createElement("span");
          charSpan.textContent = char;
          charSpan.className = "char";
          parentElement.appendChild(charSpan);
        });
      } else if (node.nodeType === Node.ELEMENT_NODE) {
        if (node.tagName === "BR") {
          parentElement.appendChild(document.createElement("br"));
        } else {
          const wrapper = document.createElement(node.tagName);
          wrapper.className = node.className || "";
          node.childNodes.forEach((child) => processNode(child, wrapper));
          parentElement.appendChild(wrapper);
        }
      }
    }

    const tempContainer = document.createElement("div");
    tempContainer.innerHTML = originalHTML;
    tempContainer.childNodes.forEach((node) => processNode(node, textBlock));

    textBlock.dataset.__animTextProcessed = "1";
    return Array.from(textBlock.querySelectorAll(".char"));
  }

  function updateAll() {
    rafScheduled = false;
    instances.forEach((inst, key) => {
      const { element, chars, settings } = inst;
      if (!document.body.contains(element)) {
        // элемент удалён из DOM — автоматически уничтожаем
        inst.destroy();
        return;
      }

      const rect = element.getBoundingClientRect();
      const H = rect.height;

      const startY = window.innerHeight * settings.startRatio;
      const endY = window.innerHeight * settings.endRatio;
      const denom = (endY - H) - startY;

      let rawProgress;
      if (Math.abs(denom) < 1e-6) {
        rawProgress = rect.top <= startY ? 0 : (rect.bottom <= endY ? 1 : 0.5);
      } else {
        rawProgress = (rect.top - startY) / denom;
      }

      const progress = clamp(rawProgress, 0, 1);
      const visibleCount = Math.floor(progress * chars.length);

      if (visibleCount === inst.visibleCount) return; // без изменений

      inst.visibleCount = visibleCount;
      chars.forEach((char, idx) => {
        if (idx < visibleCount) {
          if (!char.classList.contains("visible")) char.classList.add("visible");
        } else {
          if (char.classList.contains("visible")) char.classList.remove("visible");
        }
      });
    });
  }

  function scheduleUpdate() {
    if (!rafScheduled) {
      rafScheduled = true;
      requestAnimationFrame(updateAll);
    }
  }

  // Общие слушатели (добавляем один раз)
  let listenersEnabled = false;
  function ensureGlobalListeners() {
    if (listenersEnabled) return;
    listenersEnabled = true;
    window.addEventListener("scroll", scheduleUpdate, { passive: true });
    window.addEventListener("resize", scheduleUpdate);
    // опционально: пересчитать при загрузке шрифтов / изображений
    window.addEventListener("load", scheduleUpdate);
  }

  // Главная публичная функция
  window.animationTextPrinted = function (elementOrSelector, start, end) {
    ensureGlobalListeners();

    // Решаем, селектор ли это
    let element;
    if (typeof elementOrSelector === "string") {
      element = document.querySelector(elementOrSelector);
      if (!element) {
        console.warn("animationTextPrinted: element not found for selector", elementOrSelector);
        return null;
      }
    } else if (elementOrSelector instanceof Element) {
      element = elementOrSelector;
    } else {
      console.warn("animationTextPrinted: first argument must be selector or Element");
      return null;
    }

    // если уже создали инстанс для этого элемента — возвращаем существующий (id = element)
    const key = element;
    if (instances.has(key)) {
      return instances.get(key).publicAPI;
    }

    const settings = {
      startRatio: typeof start === "number" ? start : defaults.startRatio,
      endRatio:   typeof end === "number"   ? end   : defaults.endRatio
    };

    const chars = splitToChars(element);
    if (!chars || chars.length === 0) return null;

    const inst = {
      element,
      chars,
      settings,
      visibleCount: -1,
      ticking: false,
      destroy() {
        // убрать классы и данные, удалить из map
        this.chars.forEach(c => c.classList.remove("visible"));
        delete this.element.dataset.__animTextProcessed;
        instances.delete(key);
        // если не осталось инстансов — можно убрать глобальные слушатели (опционально)
        if (instances.size === 0) {
          window.removeEventListener("scroll", scheduleUpdate, { passive: true });
          window.removeEventListener("resize", scheduleUpdate);
          window.removeEventListener("load", scheduleUpdate);
          listenersEnabled = false;
        }
      },
      publicAPI: null // заполнится ниже
    };

    inst.publicAPI = {
      update: () => scheduleUpdate(),
      destroy: () => inst.destroy(),
      settings,
      element
    };

    instances.set(key, inst);

    // Первичная инициализация (расставит классы visible по месту)
    scheduleUpdate();

    return inst.publicAPI;
  };

})();

</script>
