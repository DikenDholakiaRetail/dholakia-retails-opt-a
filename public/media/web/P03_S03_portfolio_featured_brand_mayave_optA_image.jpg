$(document).ready(function () {
 let slideSwiper2 = new Swiper("[data-blog='slider-5']", {
    wrapperClass: "post-slider-list-4",
    slideClass: "post-slider-item-4",
    pagination: {
      //el: ".progress-bar-5",
      //type: "progressbar",
      el: "#fraction-5",
      type: "fraction",
    },
    //renderProgressbar: true,
    //totalClass: ".progress-bar-5",
    //progressbarFillClass: ".progress-fill-5",
    navigation: {
      nextEl: "#arrowNext-5",
      prevEl: "#arrowPrev-5"
    },
    speed: 500,
    slidesPerView: "auto",
    spaceBetween: 0,
    loop: true,
    //loopAdditionalSlides: 2,
    autoplay: {
      delay: 4000,
      disableOnInteraction: false
    }
  });
  const slidesCount = slideSwiper2.slides.length;
  if (slidesCount <= 2) {
     document.querySelector('[data-block="pagination-5"]').style.display = "none";
  }
  
});
</script>

