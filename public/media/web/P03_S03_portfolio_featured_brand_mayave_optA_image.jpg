@media screen and (min-width: 990px) {
  .article-main-menu-link-item.button_fly_active .link-item{
    color:#000;
  }
}

@media screen and (max-width: 991px) {
  [data-list-title="limit"] *:nth-of-type(n+5) {
    display: none;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function(){
  /*== functions for smooth scroll ==*/
  function currentYPosition() {
      if (self.pageYOffset) return self.pageYOffset;
      if (document.documentElement && document.documentElement.scrollTop)
          return document.documentElement.scrollTop;
      if (document.body.scrollTop) return document.body.scrollTop;
      return 0;
  }
  function elmYPosition(eID) {
      var elm = document.getElementById(eID);
      var y = elm.offsetTop;
      var node = elm;
      while (node.offsetParent && node.offsetParent != document.body) {
          node = node.offsetParent;
          y += node.offsetTop;
      } return y;
  }
  function smoothScroll(eID) {
      var startY = currentYPosition();
      var stopY = elmYPosition(eID);
      let width = window.screen.width;
      let vw;
      if(width >= 991){vw = -(width/100)*5;}else{vw = -(width/100)*20;}
      stopY = stopY+vw;
      var distance = stopY > startY ? stopY - startY : startY - stopY;
      if (distance < 100) {
          scrollTo(0, stopY); return;
      }
      var speed = Math.round(distance / 100);
      if (speed >= 20) speed = 20;
      var step = Math.round(distance / 60);
      var leapY = stopY > startY ? startY + step : startY - step;
      var timer = 0;
      if (stopY > startY) {
          for ( var i=startY; i<stopY; i+=step ) {
              setTimeout("window.scrollTo(0, "+leapY+")", timer * speed);
              leapY += step; if (leapY > stopY) leapY = stopY; timer++;
          } return;
      }
      for ( var i=startY; i>stopY; i-=step ) {
          setTimeout("window.scrollTo(0, "+leapY+")", timer * speed);
          leapY -= step; if (leapY < stopY) leapY = stopY; timer++;
      }
  }
  /*== functions for smooth scroll AND ==*/

  // Menu anchor
  let inThisArticleBlock =  document.querySelector('[data-block="in-this-article"]') 
  let ul = document.querySelector('.article-main-menu-link-wrap') 
  let wrap = document.querySelector('.article-main-content-wrap') 

  var h2_collection = wrap.getElementsByTagName('H2');
  for(var i=0; i<h2_collection.length;i++ ){
    let text =  h2_collection[i].innerHTML.replace(/<\/?[a-zA-Z]+>/gi, "");
    let name_link = text.replace(/\s/g, '-');
    h2_collection[i].id = name_link; 
    let new_li = document.createElement('li');
    new_li.classList.add("article-main-menu-link-item");
    new_li.setAttribute("id_link", name_link);
    var new_a=document.createElement('a');
    new_a.classList.add("link-item");
    //new_a.href ="#"+name_link;
    new_a.addEventListener('click', ()=>{
      smoothScroll(name_link);
    })
    new_a.innerHTML=text;
    new_li.appendChild(new_a);
    ul.appendChild(new_li);
  }
  
    /// прокрутка ///
  window.addEventListener('scroll', function() {
    Array.from(h2_collection).forEach(el => {
     const screenHeight = window.screen.height/2;
     var y = el.getBoundingClientRect().top;
        if(y < screenHeight && y > 0){
          document.querySelectorAll('.article-main-menu-link-item').forEach(b_f => {b_f.classList.remove("button_fly_active");});
          document.querySelector('[id_link="'+el.id+'"]').classList.add("button_fly_active");
        }else if (y > -screenHeight && y < screenHeight){
          document.querySelectorAll('.article-main-menu-link-item').forEach(b_f => {b_f.classList.remove("button_fly_active");});
          document.querySelector('[id_link="'+el.id+'"]').classList.add("button_fly_active");
        }
     });
  });
  
  let mainMenuBtnBlock = document.querySelector('.main-menu-btn-block')
  let btnShowFullList = mainMenuBtnBlock.querySelector('.btn-wrapper')
  let dataListTitle = document.querySelector('[data-list-title="limit"]');
  
  if(h2_collection.length > 4){
  	mainMenuBtnBlock.classList.add("main-menu-btn-block__visible")
  }else if(h2_collection.length === 0){
  	inThisArticleBlock.style.display = "none";
  }else{
  	mainMenuBtnBlock.classList.remove("main-menu-btn-block__visible")
  }
  
  btnShowFullList.addEventListener('click', ()=>{
    dataListTitle.setAttribute("data-list-title", "all");
    mainMenuBtnBlock.classList.remove("main-menu-btn-block__visible")
  })
  
})//DOMContentLoaded
</script></div><div class="main-menu-btn-block main-menu-btn-block__visible"><a href="#" class="btn-wrapper btn-full-list w-inline-block"><div class="btn-text btn-text--adaptation btn-text--font-size btn-text--font-size-serv">Show Full List</div></a></div></div><div class="adition-share"><div class="article-share-block"><a fs-socialshare-element="linkedin" data-share="in" href="https://www.linkedin.com/company/28596255" target="_blank" class="footer--social-wrapper footer--social-wrapper_new w-inline-block"><div class="footer-social-icon footer-social-icon-new w-embed"><svg width="100%" height="100%" viewBox="0 0 14 15" fill="none" xmlns="http://www.w3.org/2000/svg">
