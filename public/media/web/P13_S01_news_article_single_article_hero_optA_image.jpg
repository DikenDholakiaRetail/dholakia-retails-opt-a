obal .ecCbFV,.vogue-global .ctmwgM,.vogue-global .es0Neo,.vogue-global .cNHIzK,.vogue-global .dFZHBU,.vogue-global .djFrRb,.vogue-global .c2qBLK,.vogue-global .dIEOpW,.vogue-global .eNgiJC,.vogue-global .enyY4Q,.vogue-global .b3bSef,.vogue-global .bSR4sg,.vogue-global .Ito0e,.vogue-global .cuZqAB{fill:var(--color-logo-neutral)}.vogue-global.light,.vogue-global.light.standard,.vogue-global.light .standard,.vogue-global.light.theme-standard,.vogue-global.light .theme-standard{--color-text-pricing:var(--c1);--color-surface-ad:var(--a3);--color-text-ad:var(--ad3);--color-surface-navigation:var(--a3);--color-surface-navigation-elevated:var(--c16);--color-text-navigation:var(--c1);--color-text-navigation-elevated:var(--c1);--color-text-navigation-brand:var(--c1);--color-text-navigation-accent:var(--b2);--color-text-navigation-emphasis:var(--c1);--color-border-navigation:var(--c7);--color-border-sub-navigation:var(--a3);--color-border-navigation-active:var(--c1);--color-surface-navigation-overlay:var(--c9);--color-surface-navigation-feature:var(--c1);--color-text-navigation-feature:var(--a3);--color-surface-navigation-feature-brand:var(--c1);--color-surface-navigation-feature-brand-hover:var(--c14);--color-surface-navigation-feature-brand-pressed:var(--c15);--color-text-heading:var(--c1);--color-text-subheading:var(--c1);--color-text-dek:var(--c2);--color-text-pubdate:var(--c2);--color-text-image-caption:var(--c2);--color-text-image-credit:var(--c2);--color-text-blockquote:var(--c2);--color-border-story:var(--c7);--color-border-pullquote:var(--c1);--color-surface-byline-card:var(--c1);--color-text-byline-card:var(--c8);--color-text-byline:var(--c1);--color-text-byline-link:var(--c1);--color-surface-rubric-card:var(--c1);--color-text-rubric-card:var(--c8);--color-text-rubric:var(--c1);--color-surface-badge:var(--c1);--color-text-badge:var(--c8);--color-surface-status-card:var(--b2);--color-text-status-card:var(--c8);--color-text-status:var(--b2);--color-action-brand-default