\u002F\u002Fassets.vogue.com\u002Fphotos\u002F69dfcdb6914d9a854d59db56\u002F1:1\u002Fw_320,c_limit\u002Fundefined 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F69dfcdb6914d9a854d59db56\u002F1:1\u002Fw_640,c_limit\u002Fundefined 640w"}]},"isLazy":true},"contributors":{"author":{"brandSlug":"vogue","preamble":"","items":[{"name":"Laure Guilbault"}]}},"hasNativeImgLazyLoading":true}]},"visualStoryBanner":null,"featuredDeal":null,"puzzlesAndGames":null,"layoutConfigs":{},"article":{"id":"686e3e9c0db4041879f8742d","body":["div",["p","Thanks to uber-wealthy shoppers like Lauren Sánchez Bezos — who flashed not one but ",["em","two"]," oversized diamond engagement rings at her Venetian nuptials — and the middle-class consumers opting to spend their $1,000 budgets on a Cartier Trinity bracelet instead of a handbag, jewellery remains resilient as the wider luxury market contracts."],["p","This is despite price increases almost across the board, as jewellery players have sought to offset tariffs, inflation and the rising cost of gold. Analysts point out that jewellers have been more conservative in their approaches to price rises than fashion brands, and consumers see the rationale behind the uplifts as linked to the climbing value of gold. “Unlike handbags, jewellery has not priced out aspirational customers,” says Federica Levato, partner at management consultancy Bain. “It is seen as an investment and it is proving resilient.”"],["inline-embed",{"props":{"dangerousCaption":"","dangerousCredit":"","image":{"id":"686e3ff4824ebe225fc1b87c","altText":"Image may contain Bar Chart and Chart","contentType":"photo","sources":{"sm":{"width":640,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_640,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_120,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_240,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_320,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_640,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 640w","height":512},"md":{"width":768,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_768,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_120,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_240,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_320,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_640,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 640w","height":614},"lg":{"width":1024,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_1024,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_120,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_240,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_320,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_640,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_960,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 960w","height":819},"xl":{"width":1280,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_1280,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_120,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_240,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_320,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_640,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_960,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_1280,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 1280w","height":1024},"xxl":{"width":1600,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_1600,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_120,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_240,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_320,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_640,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_960,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_1280,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 1280w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3ff4824ebe225fc1b87c\u002Fmaster\u002Fw_1600,c_limit\u002FFfq8e-price-increases-across-key-luxury-icons.png 1600w","height":1280}}}},"level":"block","ref":"686e3ff4824ebe225fc1b87c","type":"image"}],["native-ad",{"position":"in-content","shouldDisplayLabel":true}],["p","Growth at Kering and Richemont’s jewellery maisons each notched up around 4 per cent in 2024, according to Morgan Stanley estimates. At LVMH, where jewellery continues to outshine other categories, gains across most brands were slightly offset by a 3 per cent dip at Fred and Tiffany. The prospects for 2025 remain broadly positive: Kering’s latest results underline the momentum of its jewellery portfolio, while LVMH reported a modest 1 per cent uptick in its watches and jewellery division, although linked to currency adjustments."],["inline-embed",{"type":"cneinterlude","props":{"brand":"vogue","embeddedVideos":[],"hasExcludedEmbed":false,"playerBase":"https:\u002F\u002Fplayer.cnevids.com","isRailEligible":false,"isRightRail":false,"relatedVideo":{"showRelatedVideo":true,"brand":"vogue","related":null,"pageSize":4}}}],["p","In recent years, jewellery houses have strengthened their product offerings by filling gaps across all price points, amplifying the visibility of their events — particularly in high jewellery — investing in cultural initiatives and refining design to differentiate beyond gemstone value alone. Their agility in seizing opportunities has allowed them to thrive."],["cm-unit"],["p","While some point to newly introduced tariffs under the Trump administration and rising gold prices as potential headwinds, these are unlikely to significantly disrupt the sector. Instead, the greater risk may lie in one of jewellery’s strengths: icons. Another challenge could come from China, once a key growth engine, and India, a market long seen as promising but slow to deliver."],["native-ad",{"position":"sponsor-product","shouldDisplayLabel":true}],["p","Here, we unpack the forces that will shape the jewellery market in the second half of 2025 and beyond."],["journey-inline-newsletter",{"newsletterType":"slim-newsletter","newsletters":[]}],["inline-newsletter",{"newsletterType":"slim-newsletter","newsletters":[]}],["h2",["strong","US tariffs and high gold prices: A partial threat"]],["p","On 2 April, the US announced a 10 per cent baseline import duty and higher reciprocal tariffs — 31 per cent for Switzerland, 20 per cent for the EU, 10 per cent for the UK, and 26 to 27 per cent for India. While the 10 per cent tariff from Europe has been in effect since 5 April, the higher tariffs have been delayed as the administration continues to negotiate trade agreements. An initial deadline of 9 July to enact them has now been pushed to 1 August. At the time of writing, the US is levying an average tariff of 51.1 per cent on imports from China."],["ad",{"position":"mid-content"}],["p","On 3 April, Pandora, the world’s largest jewellery producer by volume, with products ranging from $35 to $2,200, said that US tariffs will impact imports from key manufacturing hubs including Thailand, Vietnam, India and China. The company estimated a gross annual impact of approximately $168 million, with a projected hit of $98 million in 2025, if the reciprocal tariffs outlined on 2 April are enforced. While Pandora has not announced any price increases, it is adjusting its supply chain to serve Canada and Latin America directly, bypassing its US distribution hub."],["p","However, for higher end jewellery, the effect of tariffs may prove negligible."],["p","“The higher the price segment, the less noticeable the impact,” says Oliver Müller, founder of LuxeConsult, a consultancy for the luxury watch industry. Since tariffs apply to the import value — not to the retail price — a 31 per cent duty translates to roughly a 12 per cent retail increase, while the current 10 per cent base rate adds about 3 per cent."],["p","Cartier and Van Cleef & Arpels have already responded. Boston Consulting Group (BCG), a New York management consultancy, reports that Cartier implemented 3 per cent price increases on jewellery and 5 per cent on watches in the US as of May, keeping hikes in line with or below other markets to protect volume and consumer loyalty. In April, Van Cleef & Arpels applied 10 per cent US price increases on its icon products, with lower adjustments in Europe (+5 per cent) and China (+7 per cent), while continuing to operate under a universal pricing policy to maintain global consistency, per BCG."],["inline-embed",{"props":{"dangerousCaption":"\u003Cp\u003EVan Cleef &amp; Arpels's Fleurs d’Hawaï collection. In April, Van Cleef &amp; Arpels applied 10 per cent US price increases on its icon products.\u003C\u002Fp\u003E\n","dangerousCredit":"Photo: Courtesy of Van Cleef &amp; Arpels","image":{"id":"686e3f71824ebe225fc1b87a","altText":"Image may contain Accessories Jewelry Gemstone Necklace Amethyst and Ornament","contentType":"photo","sources":{"sm":{"width":640,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 640w","height":427},"md":{"width":768,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_768,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 640w","height":512},"lg":{"width":1024,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_1024,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 960w","height":683},"xl":{"width":1280,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 1280w","height":853},"xxl":{"width":1600,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_1600,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 1280w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71824ebe225fc1b87a\u002Fmaster\u002Fw_1600,c_limit\u002Fjewl-vogueb-july-25-inline-5.jpg 1600w","height":1067}}}},"level":"block","ref":"686e3f71824ebe225fc1b87a","type":"image"}],["p","Reflecting on the non-essential nature of luxury, Müller adds, “there may be initial hesitation, but it’s psychological — once the new prices settle in, no one thinks twice. After all, no one truly ",["em","needs"]," another bracelet or another watch.”"],["ad",{"position":"mid-content"}],["p","Small brands that are less equipped than big groups to hedge spikes in gold prices are, therefore, more likely to take the brunt. Sheherazade Goldsmith, founder of emerging jewellery brand Loquet, has a clear plan: “The US is one of our largest markets, and any shifts in import duties inevitably affect both our pricing and customer experience. That said, we’ve always believed in transparency. We include duties and taxes upfront for our international customers, so there are no hidden charges. If tariffs rise further, we’ll likely absorb part of that cost ourselves before passing anything significant onto our customers.”"],["p","Gold prices are at an all-time high of $3,283 per ounce, versus $2,358 on 8 July 2024, as geopolitical tensions and economic instability pushed investors to buy. These price fluctuations are a constant of the jewellery business for which big brands have always hedged themselves. Smaller, less shielded brands, however, may have been forced to find solutions, for example by rethinking the design of certain products to limit the gold content, or by using other materials such as platinum and silver. Some brands, such as Loquet and Lily Gabriella, have opted to increase their pricing and elevate their positioning in line with the heightened gold prices."],["h2",["strong","The new triad of jewellery strategy"]],["p","Against this challenging backdrop, brands are broadly leaning on three strategic levers to succeed: high jewellery; building cultural capital and offering a range of price points, from entry-level to high jewellery; and boosting the middle range (below $100,000)."],["p","High jewellery — defined as one-of-a-kind pieces costing north of $100,000 — may account for just 30 per cent, on average, of jewellery houses’ turnovers, but beyond its commercial weight, it is a powerful tool for building brand equity, fuelling storytelling and captivating customers through mediatised events. Unsurprisingly, luxury houses are doubling down on high jewellery: expanding their collections year-on-year and transforming their presentations into cultural events that tour the globe, with new pieces and fresh social media content at each stop."],["p","In May, for instance, Louis Vuitton invited its top clients to the Majorcan capital of Palma, where its latest high jewellery collection was staged at historic landmarks including the Castell de Bellver. Pomellato unveiled its ‘Collezione 1967’ collection — its largest high jewellery offering to date — inside Milan’s Pinacoteca di Brera, with models strolling past a statue of Napoleon posing as Caesar. Meanwhile, LVMH-owned Repossi has chosen the Musée du Quai Branly in Paris for its latest presentation, following last year’s event at the Centre Pompidou during the Brancusi retrospective, which it helped sponsor."],["inline-embed",{"props":{"dangerousCaption":"\u003Cp\u003ELouis Vuitton Virtuosity High Jewellery collection unveiling at Castell de Bellver in Mallorca.\u003C\u002Fp\u003E\n","dangerousCredit":"Photo: Courtesy of Louis Vuitton","image":{"id":"686e3f7127f60f03efe0f7c3","altText":"Image may contain Grace Balsdon Christelle Lefranc Raica Oliveira Clothing Dress Groupshot Person Adult and Wedding","contentType":"photo","sources":{"sm":{"width":640,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 640w","height":427},"md":{"width":768,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_768,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 640w","height":512},"lg":{"width":1024,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_1024,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 960w","height":683},"xl":{"width":1280,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 1280w","height":853},"xxl":{"width":1600,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_1600,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 1280w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f7127f60f03efe0f7c3\u002Fmaster\u002Fw_1600,c_limit\u002Fjewl-vogueb-july-25-inline-1.jpg 1600w","height":1067}}}},"level":"block","ref":"686e3f7127f60f03efe0f7c3","type":"image"}],["ad",{"position":"mid-content"}],["p","“These moments are crafted to strengthen relationships with our most valued clients,” says Boris Barboni, CMO of Kering-owned Pomellato. “We offer them not just access to new creations, but meaningful cultural experiences.” Pomellato has also developed Casa Pomellato, a private client experience where VICs (very important clients) can visit the brand’s ateliers, meet creative director Vincenzo Castaldo and gem master Stefano Cortecci, while commissioning bespoke pieces."],["p","Beyond staging events, culture now permeates every layer of luxury jewellery strategy, following in the footsteps of Cartier, which set the benchmark years ago with its Foundation for Contemporary Art. Bvlgari, through its own foundation, has supported major restoration projects — from the Spanish Steps in Rome, to around 150 sculptures from Italy’s storied Torlonia Collection. Pomellato partners with Venetian Heritage on restorations in Venice, while Van Cleef & Arpels, through its educational arm L’École, has collaborated with publisher Franco Maria Ricci on re-issuing classic cultural titles."],["inline-embed",{"props":{"dangerousCaption":"\u003Cp\u003EPomellato unveiled its Collezione 1967 High Jewellery collection with a gala dinner at the Pinacoteca di Brera in Milan.\u003C\u002Fp\u003E\n","dangerousCredit":"Photo: Courtesy of Pomellato","image":{"id":"686e3f715206925a8cd4f4a6","altText":"Image may contain Accessories Face Head Person Photography Portrait Jewelry Necklace Adult and Pendant","contentType":"photo","sources":{"sm":{"width":640,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 640w","height":960},"md":{"width":768,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_768,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 640w","height":1152},"lg":{"width":1024,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_1024,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 960w","height":1536},"xl":{"width":1280,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 1280w","height":1920},"xxl":{"width":1600,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_1600,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 1280w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f715206925a8cd4f4a6\u002Fmaster\u002Fw_1600,c_limit\u002Fjewl-vogueb-july-25-inline-4.jpg 1600w","height":2400}}}},"level":"block","ref":"686e3f715206925a8cd4f4a6","type":"image"}],["p","Still, brands remain laser-focused on building complete product portfolios across every price point. “While VICs are driving stronger growth than average, we’re seeing resilience across all client segments,” notes Barboni. Repossi CEO Anne de Vergeron agrees: “High jewellery and exceptional pieces remain attractive to certain clients, even in the current environment.” Yet, Repossi’s focus in recent years has been to build a collection that spans a range of prices — from pieces below $1,000, through the middle range of $10,000 to $100,000. This strategy has also been embraced by Bvlgari, which tripled its turnover in the matter of a decade."],["h2",["strong","Icons and the threat of ubiquity"]],["p","Although high jewellery captures everyone’s attention, the bulk of sales at jewellery maisons comes from repeatable designs or icons, particularly beloved classics like Cartier’s Love and Van Cleef & Arpels’s Alhambra."],["p","Iconic collections account for approximately 75 per cent of Cartier’s sales, including over €1 billion from the Love line alone in 2024, according to BCG managing director and partner Pierre Dupreelle. Dupreelle notes that icons have turbocharged jewellery houses’ growth, and their share of sales continues to grow."],["ad",{"position":"mid-content"}],["p","But while the success of icons is built on visibility, increasing ubiquity — compounded by the spread of counterfeits and Gen Z’s relaxed attitude towards dupes (#CartierDupe has over 18 million views on TikTok) — may threaten their long-term appeal."],["p","To counter this risk, Cartier and Van Cleef & Arpels have each elevated their iconic collections through more intricate versions and higher price points, all while introducing new ones. Boucheron reimagined its Quatre range as a red carpet-worthy jewel worn by Charlize Theron at the Oscars last year. At the same time, heritage brands are bringing new icons to their portfolios. Amrita Banta of Agility Research, which regularly surveys high-net-worth individuals, notes that 35 per cent of respondents have tried two or more new brands this year, a trend fashion maisons like Dior and Louis Vuitton have seized upon by establishing signature designs of their own, while simultaneously adapting them across various price points."],["inline-embed",{"props":{"dangerousCaption":"\u003Cp\u003EBoucheron Carte Blanche collection. The brand has reimagined its Quatre range.\u003C\u002Fp\u003E\n","dangerousCredit":"","image":{"id":"686e3f71d263477a717f8d32","altText":"Image may contain Body Part Finger Hand Person Face Head Photography Portrait Accessories Adult and Jewelry","contentType":"photo","sources":{"sm":{"width":640,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 640w","height":782},"md":{"width":768,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_768,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 640w","height":939},"lg":{"width":1024,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_1024,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 960w","height":1252},"xl":{"width":1280,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 1280w","height":1564},"xxl":{"width":1600,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_1600,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 1280w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f71d263477a717f8d32\u002Fmaster\u002Fw_1600,c_limit\u002Fjewl-vogueb-july-25-inline-3.jpg 1600w","height":1956}}}},"level":"block","ref":"686e3f71d263477a717f8d32","type":"image"}],["p","“In all personal luxury categories and brands, there is the paradox of exclusivity (like feeling unique, be a small circle of shared tastes or shared values) and inclusivity (like the need of brands to have a broad customer base to grow through strongly recognisable icons desired by a large number of customers). It happened with bags, now it is happening in jewellery,” says Bain’s Levato. “The key for brands lies in their ability to engage consumers meaningfully and deliver strong experiential and emotional value propositions.”"],["h2",["strong","Design over diamonds"]],["p","In June, the Gemological Institute of America (GIA) introduced a grading system specifically for laboratory-grown diamonds, separating it from the 4C system (carat, clarity, colour, cut) used for natural stones. “By introducing broader descriptors for laboratory-grown diamonds, GIA is telling consumers these are not the same products and shouldn’t be evaluated the same way,” says David Kellie, CEO of the Natural Diamond Council, which promotes consumer education on behalf of natural diamond producers."],["ad",{"position":"mid-content"}],["p","While lab-grown diamonds have surged in popularity — about half of all engagement rings in the US are set with a lab-grown diamonds, according to bridal website The Knot, while online retailer 77Diamonds reports a 30 per cent increase in diamond sales over the past five years across all types of jewellery — their prices have plummeted. Industry analyst Paul Zimnisky calculates that lab-grown diamond prices have dropped more than 80 per cent in the past decade, while the prices of natural diamonds have recovered from last year’s dip linked partly to the pressure of manmade stones and China’s slowdown. Over the past 12 months, the price of a 1.5-carat, VS-clarity, near-colourless natural diamond rose by 2 per cent, but a comparable lab-grown diamond fell by 25 per cent, he adds."],["p","This divergence reinforces the perception of lab-grown diamonds as mass-market products embraced by brands like Pandora, while luxury houses continue to rely on natural stones to maintain exclusivity."],["p","However, high jewellery is no longer defined by gems alone, as design and craftsmanship increasingly take centre stage."],["p","Louis Vuitton, for instance, has built a strong high jewellery identity through its proprietary LV Monogram Star diamond cut, inspired by the maison’s iconic flower emblem. Its collections blend graphic reinterpretations of the monogram LV initials, as well as elements drawn from the brand’s trunk-making heritage. One of the highlights of Piaget’s most recent high jewellery collection ‘Shapes of Extraleganza’ was a necklace combining nine coloured hard stones set with an inlay technique mimicking ",["em","pietra dura"],", typical in decorative objects. At Pomellato, it was chains in every size, shapes and finishes that were elevated to the realm of high jewellery in ‘Collezione 1967’, while the Milanese brand also collaborated with Gucci on an exclusive high jewellery capsule named ‘Monili’, due to be unveiled during ",["a",{"href":"https:\u002F\u002Fwww.voguebusiness.com\u002Fstory\u002Ffashion\u002Fparis-couture-week-cheat-sheet-autumn-winter-2025","class":"text link","isExternal":false},"Paris Couture Week"],"."],["inline-embed",{"props":{"dangerousCaption":"\u003Cp\u003ELouis Vuitton Virtuosity High Jewellery collection. The brand has built a strong high jewellery identity through its proprietary LV Monogram Star diamond cut, inspired by the maison’s iconic flower emblem.\u003C\u002Fp\u003E\n","dangerousCredit":"","image":{"id":"686e3f710db4041879f8742f","altText":"Image may contain Accessories Formal Wear Tie Adult Person Pendant Jewelry Ring Necklace and Baby","contentType":"photo","sources":{"sm":{"width":640,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 640w","height":427},"md":{"width":768,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_768,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 640w","height":512},"lg":{"width":1024,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_1024,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 960w","height":683},"xl":{"width":1280,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 1280w","height":853},"xxl":{"width":1600,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_1600,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_120,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_240,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_320,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_640,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_960,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_1280,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 1280w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e3f710db4041879f8742f\u002Fmaster\u002Fw_1600,c_limit\u002Fjewl-vogueb-july-25-inline-2.jpg 1600w","height":1066}}}},"level":"block","ref":"686e3f710db4041879f8742f","type":"image"}],["ad",{"position":"mid-content"}],["h2",["strong","Chinese and Indian brands rise up"]],["p","Since going global in the early 2000s, Western luxury brands spread the gospel that good taste and high craftsmanship were cultivated under the glow of the Eiffel Tower and in the cobbled streets around La Scala. The world embraced the credo — none more fervently than China, which fuelled much of the industry’s growth. But the equivalent of a Lutheran reform is underway. China and India are challenging the long-standing dominance of European maisons in their respective countries, alongside expanding abroad."],["p","In China, the meteoric rise of Laopu marks a turning point. Founded in 2009 by Xu Gaoming and established as a brand in 2016, Laopu is projected by Morgan Stanley to reach $2.8 billion in sales by 2025— surpassing Cartier’s estimated $1.5 billion. “Laopu’s sales are growing exponentially, while Cartier’s have been contracting,” notes a Morgan Stanley study led by analyst Edouard Aubin."],["inline-embed",{"props":{"dangerousCaption":"","dangerousCredit":"","image":{"id":"686e69c1c2ac5393c741b0f9","altText":"Image may contain Bar Chart and Chart","contentType":"photo","sources":{"sm":{"width":640,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_640,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_120,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_240,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_320,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_640,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 640w","height":427},"md":{"width":768,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_768,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_120,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_240,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_320,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_640,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 640w","height":512},"lg":{"width":1024,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_1024,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_120,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_240,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_320,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_640,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_960,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 960w","height":683},"xl":{"width":1280,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_1280,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_120,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_240,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_320,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_640,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_960,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_1280,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 1280w","height":853},"xxl":{"width":1600,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_1600,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_120,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_240,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_320,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_640,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_960,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 960w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_1280,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 1280w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e69c1c2ac5393c741b0f9\u002Fmaster\u002Fw_1600,c_limit\u002FFooAR-sales-of-laopu-gold-2020-to-2027.png 1600w","height":1067}}}},"level":"block","ref":"686e69c1c2ac5393c741b0f9","type":"image"}],["p","Laopu’s success — shattering the belief that heritage is a high barrier to entering luxury — is driven in part by rising gold prices and the perceived value of its products. Unlike Western brands that use 18-karat gold, Laopu uses 24-karat gold and has developed rare expertise in setting diamonds in the softer metal. With heavier, more visibly valuable products, Western brands — which have higher margins because of import duties — appear overpriced in comparison."],["p","The ‘guochao’ (or “China chic”) movement, which celebrates Chinese heritage and encourages consumers to support domestic brands, also plays a key role. Laopu has capitalised on this sentiment. In 2020, the jeweller’s sales stood at just $130 million; by 2024, they had reached $2.7 billion — trailing only Chow Tai Fook ($11.6 billion) and Lao Feng Xiang ($6.8 billion), while ahead of Chow Tai Seng ($1.9 billion) and Luk Fook ($1.8 billion). Unlike most competitors, Laopu does not rely on franchises — its directly owned stores give it tighter control over brand image and customer experience. Investors believe so much in Laopu’s potential that since its IPO in Hong Kong Stock Exchange last year, the brand’s market capitalisation soared to $18.1 billion, ahead of the giant Chow Tai Fook at $14.2 billion."],["ad",{"position":"mid-content"}],["inline-embed",{"props":{"dangerousCaption":"","dangerousCredit":"","image":{"id":"686e6a44c2ac5393c741b0fb","altText":"Image may contain Bar Chart and Chart","contentType":"photo","sources":{"sm":{"width":640,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_640,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_120,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_240,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_320,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_640,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 640w","height":427},"md":{"width":768,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_768,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_120,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_240,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_320,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_640,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 640w","height":512},"lg":{"width":1024,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_1024,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_120,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_240,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 240w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_320,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 320w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_640,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 640w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_960,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 960w","height":683},"xl":{"width":1280,"url":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_1280,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png","srcset":"https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_120,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 120w, https:\u002F\u002Fassets.vogue.com\u002Fphotos\u002F686e6a44c2ac5393c741b0fb\u002Fmaster\u002Fw_240,c_limit\u002FmtqVu-sales-of-top-five-jewellers-in-2025.png 240w, https:\u002F\u002Fasse