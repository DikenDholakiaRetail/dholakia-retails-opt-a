iv></div></div></div><div data-testid="RowWrapper" class="BaseWrap-sc-SkJtP RowWrapper-efRjVu dZoWtJ dNXSll"><div class="GridWrapper-uulHE dCnZHU grid grid-margins grid-items-2 grid-layout--adrail narrow wide-adrail" data-journey-hook="grid-wrapper"><div class="GridItem-bufwYC kKTABR grid--item grid-layout__content"><div class="ContributorsWrapper-AFVoY bmFrPZ contributors" data-testid="Contributors"></div></div></div></div><div data-testid="RowWrapper" class="BaseWrap-sc-SkJtP RowWrapper-efRjVu dZoWtJ dNXSll"><div class="GridWrapper-uulHE dCnZHU grid grid-margins grid-items-2 grid-layout--adrail narrow wide-adrail" data-journey-hook="grid-wrapper"><div class="GridItem-bufwYC kKTABR grid--item grid-layout__content"></div></div></div><div data-testid="ContentFooterBottom" class="ContentFooterBottom-cbbwZo iSuBdg"><div class="content-bottom-anchor"></div><div class="ConsumerMarketingUnitThemedWrapper-kjbXjp gnOkbl consumer-marketing-unit consumer-marketing-unit--article-footer" role="presentation" aria-hidden="true"><div class="consumer-marketing-unit__slot consumer-marketing-unit__slot--article-footer"></div><div class="journey-unit"></div></div><div data-attr-viewport-monitor="" class="recirc-list-wrapper viewport-monitor-anchor"><div class="RecircListWrapper-erQXzq eevZTj"><div data-testid="RowWrapper" class="BaseWrap-sc-SkJtP RowWrapper-efRjVu dZoWtJ dNXSll ContentFooterRelated-gScfmk cBCWd"><div class="GridWrapper-uulHE dArhxS grid grid-margins grid-items-0 SummaryCollectionGridComponent-hhdzcS kortJj summary-collection-grid RecircListDefaultOverlaySummaryCollectionGrid-fQnyMC lppMLp recirc-list__items summary-collection-grid--four-columns summary-collection-grid--TextBelowLeft" data-journey-hook="grid-wrapper"><div class="GridItem-bufwYC khuCvB grid--item"><div class="SummaryCollectionGridContent-jblwZM feOxKk"><div class="SectionTitleRoot-jqTjcU kuEUrN SummaryCollectionGridSectionTitle-bSuodM hKaCkY" data-testid="SectionTitle"><header class="BaseText-fEwdHD SectionTitleHed-iavHej kuWBC idsQtM">Read More</header></div><div class="SummaryCollectionGridItems-dygJmn cOpJvV hide-read-more-ad" data-testid="SummaryCollectionGridItems"><div class="SummaryItemWrapper-bFycXm djNIuH summary-item summary-item--has-border summary-item--no-icon summary-item--text-align-left summary-item--layout-placement-text-below summary-item--layout-position-image-left summary-item--layout-proportions-50-50 summary-item--side-by-side-align-center summary-item--side-by-side-image-right-mobile-false summary-item--standard SummaryCollectionGridSummaryItem-ilztYA kYwDqY" data-item="{&quot;dangerousHed&quot;:&quot;The State of Watches in 2026&quot;,&quot;index&quot;:0,&quot;contentType&quot;:&quot;venue&quot;,&quot;hotelLink&quot;:&quot;https://www.vogue.com/article/the-state-of-watches-in-2026#intcid=_vogue-article-bottom-recirc_ba109b0e-b16c-4d29-a5c5-3ec734f76101_text2vec1&quot;,&quot;layout&quot;:&quot;GridFourColumns&quot;}" role="button" tabindex="0"><div class="SummaryItemAssetContainer-jvvUHt iQjhGX summary-item__asset-container"><a class="SummaryItemImageLink-gEpIdB cbKlTr summary-item__image-link summary-item-tracking__image-link" href="https://www.vogue.com/article/the-state-of-watches-in-2026#intcid=_vogue-article-bottom-recirc_ba109b0e-b16c-4d29-a5c5-3ec734f76101_text2vec1" aria-hidden="true" tabindex="-1" data-component-type="recirc-river" data-recirc-id="item-image-1" data-recirc-pattern="summary-item" target="_self"><span class="SpanWrapper-kFnjvc eKnjjD responsive-asset SummaryItemResponsiveAsset-hOqdxG fVNTWC summary-item__image"><div data-testid="aspect-ratio-container" class="AspectRatioContainer-dijQOF kcORnm"><div class="aspect-ratio--overlay-container"><picture class="ResponsiveImagePicture-jKunQM gjCCFj SummaryItemResponsiveAsset-hOqdxG fVNTWC summary-item__image responsive-image"><source media="(max-width: 767px)" srcSet="https://assets.vogue.com/photos/69dccb0d8922ad4bc20f710b/1:1/w_120,c_limit/undefined 120w, https://assets.vog