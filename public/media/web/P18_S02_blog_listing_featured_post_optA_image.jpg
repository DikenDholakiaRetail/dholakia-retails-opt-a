    <style>
    .lightbox {
        letter-spacing: -4px;
        display: none;
        position: fixed;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        text-align: center;
        white-space: nowrap;
        opacity: 0;
        z-index: 2000;
    }
    .lightbox::before {
        display: inline-block;
        width: 0;
        height: 100%;
        content: "";
        vertical-align: middle;
    }
    .lightbox--matte {
        background-color: rgba(0, 0, 0, 0.5);
    }
    .lightbox__content {
        display: inline-block;
        letter-spacing: normal;
        vertical-align: middle;
        max-width: 600px;
        white-space: normal;
        z-index: 2001;
    }
    .lightbox.showing {
        display: block;
        -webkit-animation: showBox .5s;
        animation: showBox .5s;
    }
    .lightbox.shown {
        display: block;
        opacity: 1;
    }
    .lightbox.hiding {
        display: block;
        -webkit-animation: hideBox .5s;
        animation: hideBox .5s;
    }
    .lightbox.hidden {
        display: none !important;
        opacity: 0;
        visibility: visible !important;
    }
    @-webkit-keyframes showBox {
        0% {
            display: none;
            opacity: 0;
        }
        1% {
            display: block;
            opacity: 0;
        }
        100% {
            display: block;
            opacity: 1;
        }
    }
    @keyframes showBox {
        0% {
            display: none;
            opacity: 0;
        }
        1% {
            display: block;
            opacity: 0;
        }
        100% {
            display: block;
            opacity: 1;
        }
    }
    @-webkit-keyframes hideBox {
        0% {
            display: block;
            opacity: 1;
        }
        99% {
            display: block;
            opacity: 0;
        }
        100% {
            display: none;
            opacity: 0;
        }
    }
    @keyframes hideBox {
        0% {
            display: block;
            opacity: 1;
        }
        99% {
            display: block;
            opacity: 0;
        }
        100% {
            display: none;
            opacity: 0;
        }
    }

