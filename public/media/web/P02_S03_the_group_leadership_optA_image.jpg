.content, .sidebar{
	min-height:100vh
}
.home .entry-content{
	padding-top:30px
}

.genesis-nav-menu .menu-item{
	vertical-align: middle;
}

.genesis-nav-menu a {
    width: 120px;
    text-align: center;
    vertical-align: middle;
	  padding: 15px 0px;
}

.bf-wrap{
	padding:12px 0 10px;
	border-bottom:1px solid #f7f7f7
}

.bf-wrap > section{
	text-align:center
}
@media(min-width:800px){
.sidebar-content .content {
    width:75%
}

.sidebar-content .sidebar{
	 width:25%
}
	
	
}

@media(max-width:768px){
	#genesis-content >article {
    margin-top: 0 !important;
	}
}

#fancybox-wrap{
	z-index: 99999999999999999999999 !important;
}
#media_image-2{
	    padding: 50px 60px 21px;
	
}

.site-header{
	    z-index: 9999999999;
	position: fixed;
    background: #fff;
	width:100%;
	
}
#genesis-content >article{
	    margin-top: -43PX;
}
.site-header > .wrap{
	padding-bottom:0
}
.sticky{
	border-bottom:0.5px solid #e5e5e5
}

.site-inner{
	padding-top: 158px;
}
.middle a{
		font-size:1.8rem
}
.middle .menu-item{
	margin-top:-15px;
}
.middle{
	text-align:center;
	margin-top:-20px;
	    margin-bottom: -12px;
    padding-top: 0;
}

.middle-nav{
	color: #000;
    margin-top: 10px;
	display: flex;
	gap: 10px;
	justify-content: center;
  padding-bottom: 10px;
	margin-top: 0px;
}

.middle-nav a {
    color: #fff;
    text-decoration: none;
    font-size: 18px;
    background: #000;
    padding: 5px 15px;
	 transition: all 0.3s ease;
}

.middle-nav a:hover {
    color: #000;
    background: #fff;
	border:dashed #000 2px;
	 transition: all 0.3s ease;
}

.middle-nav a:active {
    color: #000;
    background: #fff;
	border:solid #000 2px;
	 transition: all 0.3s ease;
}



.entry-pagination.pagination a{
	border: 1px solid #000;
    padding: 10px;
    color: #fff;
    background: #585858;
    text-decoration: none;
}

.entry-pagination.pagination a:hover{
	 background: #000;
}
.home .entry-title { display: none; }

@media(max-width:800px){
	.page-id-33449 .page img{
		width:100%;
		margin:5px auto;
		text-align:center
	}
	
}
@media(max-width:480px){
	#genesis-content >article {
    margin-top: -43px !important;
	}
	.sticky-message{
	  top:0
  }
	.site-header{
	
	position: relative;
    background: #fff;
	width:100%;
	
}
	
	.site-inner{
	padding-top: 5%;
}

	.page-id-25 tr,.page-id-25 td{
		width:100%;
		display:block;
		padding: 0;
	}
	.page-id-25 img,.page-id-35097 img{width:100%}
	.page-id-25 .alignleft,.page-id-25 .alignright,.page-id-35097 .alignleft,.page-id-35097 .alignright{
	float:none;
		text-align:center;
				margin: 0 auto;
	}

	.page-id-25 .button{
	width:100%;
			margin-bottom:5px
	}

	.page-id-25 table p{
	margin:0
	}
	
	.home tr,.home td{
		width:100%;
		display:block;
		padding: 0;
	}
	.home img{width:100%}
		.home figure{width:100% !important;max-width:100% !important}
	.home .alignleft,.home .alignright{
	float:none;
		text-align:center;
				margin: 0 auto;
	}

	.home .button{
	width:100%;
			margin-bottom:5px
	}

	.home table p{
	margin:0
	}
	.menu-toggle, .sub-menu-toggle {
    font-size: 2rem;
	}
	
	#menu-left-head > .menu-item >a{
		font-weight:bold
	}

}

.page-id-35097 .entry-content{
	list-style-position: inside;
}
.breadcrumb{padding-top: 5px;}

.lwptoc_items > .lwptoc_itemWrap > .lwptoc_item > a > .lwptoc_item_label{
   font-weight: bold !important
}

.lwptoc_items > .lwptoc_itemWrap > .lwptoc_item{
    border-bottom: 1px solid #ccc;
    margin-bottom: 10px;
    padding-bottom: 5px
}

.lwptoc_items > .lwptoc_itemWrap > .lwptoc_item:last-child{
	border:none
}

.wp-block-image figcaption { text-align: center;}

.wp-block-image figcaption { font-size: 14px;}

.sticky-message{
	left:0;
	z-index:0
}

.site-title {
    font-size: 2.3rem;
    max-width: 280px; 
    margin: 0 auto 10px auto; 
}

/* ============================================
   MENU COLORS - RED TOWER PALETTE
   ============================================ */

/* Menu font color - Charcoal */
.genesis-nav-menu a {
    color: #292C17;
}

/* Menu hover - Sky Blue + Bold */
.genesis-nav-menu > .menu-item > a:hover,
.genesis-nav-menu > .menu-item > a:focus,
.genesis-nav-menu > .menu-item:hover > a {
    color: #2992BF;
    font-weight: bold;
    transition: color 0.3s ease;
}

/* Dropdown menu container */
.genesis-nav-menu .sub-menu {
    border-top: 3px solid #2992BF;
    background: transparent !important;
}

/* EACH CELL background - Turquoise */
.genesis-nav-menu .sub-menu li {
    background-color: #4CBED9 !important;
}

/* Cell hover background - Sky Blue */
.genesis-nav-menu .sub-menu li:hover {
    background-color: #2992BF !important;
}

/* Dropdown links - Dark text */
.genesis-nav-menu .sub-menu a {
    color: #292C17;
    background: transparent !important;
    display: block;
}

/* Dropdown link hover - White text */
.genesis-nav-menu .sub-menu a:hover,
.genesis-nav-menu .sub-menu a:focus {
    color: #FFFFFF !important;
    background: transparent !important;
    font-weight: bold;
}

/* Active/current cell - Sky Blue background with coral left border */
.genesis-nav-menu .sub-menu .current-menu-item {
    background-color: #2992BF !important;
    border-left: 4px solid #F0742A !important;
    box-sizing: border-box;
}

/* Active cell text - Cream white */
.genesis-nav-menu .sub-menu .current-menu-item a {
    color: #F9F6EF !important;
    font-weight: bold;
}

/* Current page (top level) - Coral */
.genesis-nav-menu .current-menu-item > a,
.genesis-nav-menu .current-page-ancestor > a {
    color: #F0742A;
    font-weight: 600;
}

/* Header Logo Modifications */
@media screen and (min-width:780px)
{
.header-image .site-title > a
{
	position: absolute;
    top: 0;
    left: 0;
    z-index: -1;
    min-height: 151px;
}
	
	.header-image .site-title > a:hover
	{
		background-image:url('https://solarisstudios.com/wp-content/uploads/2026/02/Solaris-coral-burst.png') !important;
	}

.middle-nav {
    margin-top: 58px;
}
.site-inner
	{
		padding-top:180px;
	}
	
	ul#menu-right-head
	{
		text-align:left;
		padding-left:30px;
	}
	
	ul#menu-left-head
	{
		text-align:right;
		padding-right:30px;
	}
}



/* ================================
 *    FOOTER LAYOUT
 *    ================================ */
.site-footer {
	  background: #1a1a1a !important;
	  text-align: left !important;
}
.site-footer .wrap {
	  max-width: 1140px;
	  margin: 0 auto;
	  padding: 0 20px !important;
	  text-align: left !important;
}
.site-footer .wrap > p:first-child {
	  display: none;
}
.site-footer .wrap > div:first-of-type {
	  display: flex !important;
	  flex-wrap: wrap;
	  justify-content: space-between;
	  gap: 30px;
	  padding: 40px 0 20px;
	  font-size: 14px;
	  line-height: 1.8;
	  color: #999;
}
.site-footer .wrap > div:first-of-type > div {
	  flex: 1;
	  min-width: 220px;
	  text-align: left !important;
}
.site-footer .wrap > div:first-of-type strong {
	  color: #fff;
	  font-size: 15px;
	  text-transform: uppercase;
	  letter-spacing: 1px;
	  display: block;
	  margin-bottom: 8px;
}
.site-footer .wrap > div:first-of-type a {
	  color: #999 !important;
	  text-decoration: none;
}
.site-footer .wrap > div:first-of-type a:hover {
	  color: #fff !important;
}
.site-footer .wrap > div:last-child,
.site-footer .wrap > p:last-child {
	  text-align: center;
	  padding: 20px 0 10px;
	  font-size: 12px;
	  color: #666;
	  border-top: 1px solid #333;
	  max-width: 1140px;
	  margin: 0 auto;
}
.site-footer .footer-book-btn {
	  display: inline-block;
	  padding: 10px 24px;
