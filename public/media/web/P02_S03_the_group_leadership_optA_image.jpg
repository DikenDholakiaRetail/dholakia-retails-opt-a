jQuery(document).ready(function($){
  var sticky = $(".sticky-message").detach();
  $(".home .entry-title").remove();
  var middle = $(".genesis-nav-menu.middle").detach();
  $(".site-header").append(middle);

  // Add buttons right before </header>
  var $buttons = $('<div class="middle-nav"><a href="https://solarisstudios.com/galleries/schedule/">BOOK NOW</a> <a class="btn download" href="https://solarisstudios.com/galleries/">DOWNLOAD</a></div>');
  $(".site-header").append($buttons);

  // Add sticky-message right before </header>
  $(".site-header").append(sticky);

  var pag = $(".entry-pagination.pagination").detach();
  $(".sharedaddy").before(pag);

  $("a[href='#top']").click(function(){
    window.scrollTo(0,0);
    return false;
  });

  var cc = $(".before-header .wrap").detach();
  cc.removeClass('wrap').addClass("bf-wrap");
  $(".site-header").prepend(cc);
  $(".before-header").hide();
});

jQuery(window).scroll(function(){
  if (jQuery(this).scrollTop() >= 5){
    jQuery(".site-header").addClass('sticky');
  } else {
    jQuery(".site-header").removeClass('sticky');
  }
});
